#!/usr/bin/env bash
#MISE description="Build the static docs site into docs/public"
#MISE tools={deno="latest"}
#MISE dir="./docs"
#MISE sources=["docs/.config/dodeca.styx", "docs/content/**/*.md", "docs/data/**/*.yaml", "docs/templates/**/*.html", "docs/static/**/*", "docs/deno.json", "docs/deno.lock", "docs/package.json", "crates/ksbh-ui/static/css/shared.css"]
#MISE outputs=["docs/public/**/*"]

set -euo pipefail

export PATH="${HOME}/.cargo/bin:${HOME}/.local/bin:${PATH}"

if ! command -v ddc >/dev/null 2>&1; then
  dodeca_version="${KSBH_DODECA_VERSION:-v0.13.0}"
  curl --proto '=https' --tlsv1.2 -fsSL \
    "https://github.com/bearcove/dodeca/releases/download/${dodeca_version}/dodeca-installer.sh" \
    | DODECA_VERSION="${dodeca_version}" DODECA_INSTALL_DIR="${HOME}/.local/bin" sh
fi

deno install --allow-scripts --node-modules-dir=auto
deno task build:css
ddc build
