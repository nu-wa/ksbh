#!/usr/bin/env bash
#MISE description="Build the static docs container image"
#MISE alias="bdsi"
#MISE sources=["docker/build/docs-site.Dockerfile", "docs/public/**/*"]

set -euo pipefail
. "$(dirname "$0")/lib.sh"

require_docker

mise run build-docs-site

image_name="${KSBH_DOCS_SITE_IMAGE:-ksbh-docs-site:local}"

DOCKER_BUILDKIT=1 docker build \
  --load \
  --file docker/build/docs-site.Dockerfile \
  --tag "${image_name}" \
  .
