#!/usr/bin/env bash
#MISE description="Run Miri against the ksbh-modules-sdk FFI smoke test"
#MISE alias="miri-ffi"
#MISE sources=["crates/Cargo.toml", "crates/Cargo.lock", "crates/ksbh-core/**", "crates/ksbh-modules-sdk/**"]

set -euo pipefail
. "$(dirname "$0")/lib.sh"

require_cmd cargo

cargo +nightly miri test --manifest-path crates/Cargo.toml -p ksbh-modules-sdk --test ffi_miri -- --nocapture --test-threads=1
