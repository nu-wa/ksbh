#!/usr/bin/env bash
#MISE description="Run Miri against the ksbh-modules-sdk FFI smoke test"
#MISE alias="miri-ffi"
#MISE sources=["crates/Cargo.toml", "crates/Cargo.lock", "crates/ksbh-core/**", "crates/ksbh-modules-sdk/**"]

set -euo pipefail
. "$(dirname "$0")/lib.sh"

require_cmd cargo

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
miri_target_dir="${KSBH_MIRI_TARGET_DIR:-${repo_root}/crates/target/miri-ci-$(date +%s)-$$}"

mkdir -p "${miri_target_dir}"
export CARGO_TARGET_DIR="${miri_target_dir}"
export CARGO_BUILD_JOBS="${CARGO_BUILD_JOBS:-1}"
unset RUSTFLAGS
unset CARGO_ENCODED_RUSTFLAGS

MIRI_SYSROOT="$(cargo +nightly miri setup --print-sysroot)"
export MIRI_SYSROOT
cargo +nightly miri test --manifest-path crates/Cargo.toml -p ksbh-modules-sdk --test ffi_miri -- --nocapture --test-threads=1
