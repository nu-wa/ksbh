#!/usr/bin/env bash
#MISE description="Build a real test cdylib and run native host-side dynamic module integration tests"
#MISE tools={rust="1.92.0"}

set -euo pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"

cd "$repo_root"

dynamic_smoke_loops="${KSBH_DYNAMIC_SMOKE_LOOPS:-200}"

echo "building dynamic ffi smoke module"
cargo build --manifest-path crates/Cargo.toml -p dynamic-ffi-smoke

case "$(uname -s)" in
  Darwin)
    dynamic_module_ext="dylib"
    ;;
  MINGW*|MSYS*|CYGWIN*|Windows_NT)
    dynamic_module_ext="dll"
    ;;
  *)
    dynamic_module_ext="so"
    ;;
esac

export KSBH_DYNAMIC_MODULE_LIB="$repo_root/crates/target/debug/libdynamic_ffi_smoke.${dynamic_module_ext}"
export KSBH_DYNAMIC_SMOKE_LOOPS="$dynamic_smoke_loops"

echo "running native host-side dynamic module integration test with loops=$KSBH_DYNAMIC_SMOKE_LOOPS"
cargo test \
  --manifest-path crates/Cargo.toml \
  -p ksbh-core \
  --test module_host_dynamic \
  -- \
  --nocapture \
  --test-threads=1
